<Window x:Class="AutoActivator.Gui.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connexion - AutoActivator" Height="350" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F3F3F3">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Authentification Mainframe" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="Identifiant (ex: XA...):" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
        <TextBox x:Name="TxtUsername" Grid.Row="2" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,0,15" CharacterCasing="Upper"/>

        <TextBlock Grid.Row="3" Text="Mot de passe:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
        <PasswordBox x:Name="TxtPassword" Grid.Row="4" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,0,25"/>

        <Button x:Name="BtnLogin" Grid.Row="5" Content="Se connecter" Click="BtnLogin_Click" Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="14" Padding="10" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>