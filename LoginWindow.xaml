<Window x:Class="AutoActivator.Gui.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoActivator - Connexion" Height="250" Width="320"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="Veuillez entrer vos identifiants" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <TextBlock Text="Nom d'utilisateur (UID) :" Margin="0,0,0,5"/>
        <TextBox x:Name="TxtUsername" Height="25" Margin="0,0,0,15"/>

        <TextBlock Text="Mot de passe :" Margin="0,0,0,5"/>
        <PasswordBox x:Name="TxtPassword" Height="25" Margin="0,0,0,20"/>

        <Button x:Name="BtnLogin" Content="Se connecter" Height="30" Width="120"
                Click="BtnLogin_Click" IsDefault="True"/>
    </StackPanel>
</Window>