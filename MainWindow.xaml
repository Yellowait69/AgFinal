<Window x:Class="AutoActivator.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E.T.L COMPARISON TOOL" Height="800" Width="1100" Background="#F3F3F3" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Foreground" Value="#7F8C8D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="CancelButtonStyle">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Foreground" Value="#7F8C8D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#2C3E50">
            <TextBlock Text="E.T.L" Foreground="White" FontSize="26" Margin="20,30,20,10" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="COMPARISON TOOL" Foreground="#BDC3C7" FontSize="12" Margin="0,0,0,30" HorizontalAlignment="Center"/>

            <Button x:Name="BtnActivation" Content="⚡ Activation" Padding="12" Margin="10,5" Click="BtnActivation_Click" Background="#1ABC9C" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
            <Button x:Name="BtnExtraction" Content="📥 Extraction" Padding="12" Margin="10,5" Click="BtnExtraction_Click" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
            <Button x:Name="BtnComparison" Content="📊 Comparison" Padding="12" Margin="10,5" Click="BtnComparison_Click" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="GridExtraction" Grid.Row="0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Extraction Module" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                </StackPanel>

                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,0,0,15">
                    <TabItem Header="📄 Single Contract" FontSize="14" FontWeight="SemiBold">
                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Extract a specific contract or demand from one or both environments." Margin="0,0,0,15" Foreground="#7F8C8D"/>

                                <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                                    <TextBlock Text="Input Type:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton x:Name="RbSearchContract" Content="Contract Number" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" Checked="InputType_Checked"/>
                                    <RadioButton x:Name="RbSearchDemand" Content="Demand ID" VerticalAlignment="Center" Cursor="Hand" Checked="InputType_Checked"/>
                                </StackPanel>

                                <TextBlock Text="Environment D000 (Value):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBox x:Name="TxtSingleD" Margin="0,0,0,15" Padding="8" FontSize="14" BorderBrush="#DCDDE1" ToolTip="Leave empty to skip D000"/>

                                <TextBlock Text="Environment Q000 (Value):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBox x:Name="TxtSingleQ" Margin="0,0,0,20" Padding="8" FontSize="14" BorderBrush="#DCDDE1" ToolTip="Leave empty to skip Q000"/>

                                <Button x:Name="BtnRunSingle" Content="Run Single Extraction" Click="BtnRunSingle_Click" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Right" Width="220"/>
                            </StackPanel>
                        </Border>
                    </TabItem>

                    <TabItem Header="📁 Batch Extraction (CSV)" FontSize="14" FontWeight="SemiBold">
                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Select CSV files to extract multiple contracts for each environment." Margin="0,0,0,15" Foreground="#7F8C8D"/>

                                <TextBlock Text="Environment D000 (CSV File):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtBatchD" IsReadOnly="True" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,10,0"/>
                                    <Button Content="Browse..." Grid.Column="1" Padding="15,8" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseD_Click"/>
                                </Grid>

                                <TextBlock Text="Environment Q000 (CSV File):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtBatchQ" IsReadOnly="True" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,10,0"/>
                                    <Button Content="Browse..." Grid.Column="1" Padding="15,8" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseQ_Click"/>
                                </Grid>

                                <Button x:Name="BtnRunBatch" Content="Run Batch Extraction" Click="BtnRunBatch_Click" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Right" Width="220"/>
                            </StackPanel>
                        </Border>
                    </TabItem>
                </TabControl>

                <Grid Grid.Row="2" Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Session History" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,10"/>

                    <ListView x:Name="ListHistory" Grid.Row="1" Background="White" BorderBrush="#DCDDE1" BorderThickness="1" AlternationCount="2">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5"/>
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F9F9F9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Time}" Width="75"/>
                                <GridViewColumn Header="Environment" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Product}" FontWeight="Bold" Foreground="#8E44AD"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Contract ID" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ContractId}" FontWeight="Bold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Internal ID" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding InternalId}" Foreground="#2980B9" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Premium" Width="95">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Premium}" FontWeight="SemiBold" Foreground="#E67E22"/>
                                                <TextBlock Text=" €" Foreground="#E67E22"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="UCON ID" DisplayMemberBinding="{Binding Ucon}" Width="115"/>
                                <GridViewColumn Header="Demand ID" DisplayMemberBinding="{Binding Hdmd}" Width="115"/>
                                <GridViewColumn Header="Result" DisplayMemberBinding="{Binding Test}" Width="120"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>

            <Grid x:Name="GridActivation" Grid.Row="0" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Activation Module" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                </StackPanel>

                <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Global Activation Settings" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Environment:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <ComboBox x:Name="CmbActEnv" Margin="0,0,0,15" Padding="6" FontSize="14" BorderBrush="#DCDDE1" SelectedIndex="0">
                                    <ComboBoxItem Content="D000 (D)" Tag="D"/>
                                    <ComboBoxItem Content="Q000 (Q)" Tag="Q"/>
                                </ComboBox>

                                <TextBlock Text="CUS Code:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBox x:Name="TxtActCus" Margin="0,0,0,15" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Text="XXX"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Bureau Number (BUCP):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <ComboBox x:Name="CmbActBucp" Margin="0,0,0,15" Padding="6" FontSize="14" BorderBrush="#DCDDE1" SelectedIndex="0">
                                    <ComboBoxItem Content="382"/>
                                    <ComboBoxItem Content="49797"/>
                                </ComboBox>

                                <TextBlock Text="Payment Command (CMDPMT):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <ComboBox x:Name="CmbActCmdpmt" Margin="0,0,0,15" Padding="6" FontSize="14" BorderBrush="#DCDDE1" SelectedIndex="0">
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="X"/>
                                    <ComboBoxItem Content="H"/>
                                    <ComboBoxItem Content="G"/>
                                    <ComboBoxItem Content="Z"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="0,0,0,15">
                    <TabItem Header="📄 Single Activation" FontSize="14" FontWeight="SemiBold">
                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Provide the contract number. The system will auto-format it and fetch the premium amount from the database." Margin="0,0,0,15" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                                <TextBlock Text="Contract Number:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBox x:Name="TxtActContract" Margin="0,0,0,25" Padding="8" FontSize="14" BorderBrush="#DCDDE1"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="BtnCancelSingleAct" Content="🛑 Cancel" Click="BtnCancelActivation_Click" Style="{StaticResource CancelButtonStyle}" Width="120" Margin="0,0,10,0" IsEnabled="False"/>
                                    <Button x:Name="BtnRunSingleAct" Content="🚀 Run Single Activation" Click="BtnRunSingleActivation_Click" Style="{StaticResource ActionButtonStyle}" Width="220"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </TabItem>

                    <TabItem Header="📁 Batch Activation (CSV)" FontSize="14" FontWeight="SemiBold">
                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Select a CSV file containing multiple contracts and premiums to activate them sequentially." Margin="0,0,0,15" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                                <TextBlock Text="CSV File path:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <Grid Margin="0,0,0,25">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtBatchActCsv" IsReadOnly="True" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,10,0"/>
                                    <Button Content="Browse..." Grid.Column="1" Padding="15,8" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseActCsv_Click"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="BtnCancelBatchAct" Content="🛑 Cancel" Click="BtnCancelActivation_Click" Style="{StaticResource CancelButtonStyle}" Width="120" Margin="0,0,10,0" IsEnabled="False"/>
                                    <Button x:Name="BtnRunBatchAct" Content="🚀 Run Batch Activation" Click="BtnRunBatchActivation_Click" Style="{StaticResource ActionButtonStyle}" Width="220"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>

            <Grid x:Name="GridComparison" Grid.Row="0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Comparison Module" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                </StackPanel>

                <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Select the base and target CSV files to compare. All tables within the files will be analyzed automatically." Margin="0,0,0,15" Foreground="#7F8C8D" TextWrapping="Wrap"/>

                        <TextBlock Text="Base Extraction File:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtBaseFile" IsReadOnly="True" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,10,0" Background="#F9F9F9"/>
                            <Button Content="Browse..." Grid.Column="1" Padding="15,8" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseBase_Click"/>
                        </Grid>

                        <TextBlock Text="Target Extraction File (to compare against):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtTargetFile" IsReadOnly="True" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,10,0" Background="#F9F9F9"/>
                            <Button Content="Browse..." Grid.Column="1" Padding="15,8" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseTarget_Click"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnOpenComparisonFolder" Content="📁 Open Report Folder" Click="BtnOpenFolder_Click" Background="#3498DB" Foreground="White" Padding="15,10" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="BtnRunComparison" Content="🚀 Run Deep Comparison" Click="BtnRunComparisonAction_Click" Style="{StaticResource ActionButtonStyle}" Width="240" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Analysis Report" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,10"/>

                    <Border Grid.Row="1" BorderBrush="#2C3E50" BorderThickness="2" CornerRadius="4" Background="#1E272E">
                        <TextBox x:Name="TxtComparisonResults"
                                 Background="Transparent"
                                 Foreground="#ECF0F1"
                                 FontFamily="Consolas"
                                 FontSize="13"
                                 Padding="15"
                                 BorderThickness="0"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 Text="System is ready. Awaiting configuration..."/>
                    </Border>
                </Grid>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,15,0,0">
                <ProgressBar x:Name="PrgLoading" IsIndeterminate="True" Height="4" Margin="0,0,0,10" Visibility="Collapsed" Foreground="#3498DB"/>
                <TextBlock x:Name="TxtStatus" FontSize="14" TextWrapping="Wrap" Foreground="#2F3640" FontWeight="SemiBold" Text="Ready."/>
                <TextBlock x:Name="LnkFile" Visibility="Collapsed" Margin="0,5,0,0" FontSize="14">
                    <Hyperlink Click="Hyperlink_Click" Foreground="#2980B9" FontWeight="Bold">
                        <Run Text="📁 Click here to open generated file/report"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

        </Grid>
    </Grid>
</Window>