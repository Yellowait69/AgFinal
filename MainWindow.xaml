<Window x:Class="AutoActivator.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E.T.L COMPARISON TOOL" Height="800" Width="1100" Background="#F3F3F3" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ActionButtonStyle">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Foreground" Value="#7F8C8D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" x:Key="CancelButtonStyle">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                    <Setter Property="Foreground" Value="#7F8C8D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#2C3E50">
            <TextBlock Text="E.T.L" Foreground="White" FontSize="26" Margin="20,30,20,10" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="COMPARISON TOOL" Foreground="#BDC3C7" FontSize="12" Margin="0,0,0,30" HorizontalAlignment="Center"/>

            <Button x:Name="BtnActivation" Content="⚡ Activation" Padding="12" Margin="10,5" Click="BtnActivation_Click" Background="#1ABC9C" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
            <Button x:Name="BtnExtraction" Content="📥 Extraction" Padding="12" Margin="10,5" Click="BtnExtraction_Click" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
            <Button x:Name="BtnComparison" Content="📊 Comparison" Padding="12" Margin="10,5" Click="BtnComparison_Click" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>

            <Button x:Name="BtnHelp" Content="❓ Help &amp; Docs" Padding="12" Margin="10,5" Click="BtnHelp_Click" Background="#8E44AD" Foreground="White" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid x:Name="GridExtraction" Grid.Row="0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Extraction Module" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                </StackPanel>

                <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Global Extraction Settings" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Environment:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <ComboBox x:Name="CmbExtEnv" Margin="0,0,0,0" Padding="6" FontSize="14" BorderBrush="#DCDDE1" SelectedIndex="0" SelectionChanged="CmbExtEnv_SelectionChanged">
                                    <ComboBoxItem Content="D000 (D)" Tag="D"/>
                                    <ComboBoxItem Content="Q000 (Q)" Tag="Q"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Channel:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <ComboBox x:Name="CmbExtChannel" Margin="0,0,0,0" Padding="6" FontSize="14" BorderBrush="#DCDDE1" SelectedIndex="0" SelectionChanged="CmbExtChannel_SelectionChanged">
                                    <ComboBoxItem Content="C01" Tag="C01"/>
                                    <ComboBoxItem Content="C03" Tag="C03"/>
                                    <ComboBoxItem Content="C05" Tag="C05"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="0,0,0,15">

                    <TabItem Header="📄 Single Contract" FontSize="14" FontWeight="SemiBold">
                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Extract a specific contract or demand from the selected environment." Margin="0,0,0,15" Foreground="#7F8C8D"/>

                                <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                                    <TextBlock Text="Input Type:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton x:Name="RbSearchContract" Content="Contract Number" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" Checked="InputType_Checked"/>
                                    <RadioButton x:Name="RbSearchDemand" Content="Demand ID" VerticalAlignment="Center" Cursor="Hand" Checked="InputType_Checked"/>
                                </StackPanel>

                                <TextBlock Text="Contract Number / Demand ID:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBox x:Name="TxtExtContract" Margin="0,0,0,20" Padding="8" FontSize="14" BorderBrush="#DCDDE1"/>

                                <Button x:Name="BtnRunSingle" Content="Run Single Extraction" Click="BtnRunSingle_Click" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Right" Width="220"/>
                            </StackPanel>
                        </Border>
                    </TabItem>

                    <TabItem Header="📁 Batch Extraction (CSV)" FontSize="14" FontWeight="SemiBold">
                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Select a CSV or Excel file to extract multiple contracts for the selected environment." Margin="0,0,0,15" Foreground="#7F8C8D"/>

                                <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                                    <TextBlock Text="Input Type:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton x:Name="RbBatchSearchContract" Content="Contract Number" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" Checked="BatchInputType_Checked"/>
                                    <RadioButton x:Name="RbBatchSearchDemand" Content="Demand ID" VerticalAlignment="Center" Cursor="Hand" Checked="BatchInputType_Checked"/>
                                </StackPanel>

                                <TextBlock Text="Data File path (CSV/XLS):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtBatchExtCsv" IsReadOnly="True" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,10,0"/>
                                    <Button Content="Browse..." Grid.Column="1" Padding="15,8" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseExtCsv_Click"/>
                                </Grid>

                                <Button x:Name="BtnRunBatch" Content="Run Batch Extraction" Click="BtnRunBatch_Click" Style="{StaticResource ActionButtonStyle}" HorizontalAlignment="Right" Width="220"/>
                            </StackPanel>
                        </Border>
                    </TabItem>
                </TabControl>

                <Grid Grid.Row="3" Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Session History" FontWeight="Bold" Foreground="#7F8C8D" VerticalAlignment="Center"/>

                        <Button x:Name="BtnClearHistory" Content="🗑️ Clear History"
                                HorizontalAlignment="Right" Padding="12,5"
                                Background="#E74C3C" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontWeight="Bold"
                                Click="BtnClearHistory_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <ListView x:Name="ListHistory" Grid.Row="1" Background="White" BorderBrush="#DCDDE1" BorderThickness="1" AlternationCount="2">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5"/>
                                <Style.Triggers>
                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F9F9F9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" DisplayMemberBinding="{Binding Time}" Width="75"/>
                                <GridViewColumn Header="Environment" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Product}" FontWeight="Bold" Foreground="#8E44AD"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Contract ID" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ContractId}" FontWeight="Bold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Internal ID" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding InternalId}" Foreground="#2980B9" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Premium" Width="95">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Premium}" FontWeight="SemiBold" Foreground="#E67E22"/>
                                                <TextBlock Text=" €" Foreground="#E67E22"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="UCON ID" DisplayMemberBinding="{Binding Ucon}" Width="115"/>
                                <GridViewColumn Header="Demand ID" DisplayMemberBinding="{Binding Hdmd}" Width="115"/>
                                <GridViewColumn Header="Result" DisplayMemberBinding="{Binding Test}" Width="120"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>

            <Grid x:Name="GridActivation" Grid.Row="0" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Activation Module" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                </StackPanel>

                <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Global Activation Settings" FontWeight="Bold" FontSize="16" Foreground="#2C3E50" Margin="0,0,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Environment:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <ComboBox x:Name="CmbActEnv" Margin="0,0,0,15" Padding="6" FontSize="14" BorderBrush="#DCDDE1" SelectedIndex="0" SelectionChanged="CmbActEnv_SelectionChanged">
                                    <ComboBoxItem Content="D000 (D)" Tag="D"/>
                                    <ComboBoxItem Content="Q000 (Q)" Tag="Q"/>
                                </ComboBox>

                                <TextBlock Text="Channel:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <ComboBox x:Name="CmbActChannel" Margin="0,0,0,15" Padding="6" FontSize="14" BorderBrush="#DCDDE1" SelectedIndex="0" SelectionChanged="CmbActChannel_SelectionChanged">
                                    <ComboBoxItem Content="C01" Tag="C01"/>
                                    <ComboBoxItem Content="C03" Tag="C03"/>
                                    <ComboBoxItem Content="C05" Tag="C05"/>
                                </ComboBox>

                                <TextBlock Text="CUS Code:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBox x:Name="TxtActCus" Margin="0,0,0,15" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Text="XXX"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Bureau Number (BUCP):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <ComboBox x:Name="CmbActBucp" Margin="0,0,0,15" Padding="6" FontSize="14" BorderBrush="#DCDDE1" SelectedIndex="0">
                                    <ComboBoxItem Content="382"/>
                                    <ComboBoxItem Content="49797"/>
                                </ComboBox>

                                <TextBlock Text="Payment Command (CMDPMT):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <ComboBox x:Name="CmbActCmdpmt" Margin="0,0,0,15" Padding="6" FontSize="14" BorderBrush="#DCDDE1" SelectedIndex="0">
                                    <ComboBoxItem Content="8"/>
                                    <ComboBoxItem Content="X"/>
                                    <ComboBoxItem Content="H"/>
                                    <ComboBoxItem Content="G"/>
                                    <ComboBoxItem Content="Z"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Margin="0,0,0,15">

                    <TabItem Header="📄 Single Activation" FontSize="14" FontWeight="SemiBold">
                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Provide the contract number or Demand ID. The system will auto-format it and fetch the premium amount from the database." Margin="0,0,0,15" Foreground="#7F8C8D" TextWrapping="Wrap"/>

                                <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                                    <TextBlock Text="Input Type:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton x:Name="RbActSearchContract" Content="Contract Number" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" Checked="ActInputType_Checked"/>
                                    <RadioButton x:Name="RbActSearchDemand" Content="Demand ID" VerticalAlignment="Center" Cursor="Hand" Checked="ActInputType_Checked"/>
                                </StackPanel>

                                <TextBlock Text="Contract Number / Demand ID:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <TextBox x:Name="TxtActContract" Margin="0,0,0,25" Padding="8" FontSize="14" BorderBrush="#DCDDE1"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="BtnCancelSingleAct" Content="🛑 Cancel" Click="BtnCancelActivation_Click" Style="{StaticResource CancelButtonStyle}" Width="120" Margin="0,0,10,0" IsEnabled="False"/>
                                    <Button x:Name="BtnRunSingleAct" Content="🚀 Run Single Activation" Click="BtnRunSingleActivation_Click" Style="{StaticResource ActionButtonStyle}" Width="220"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </TabItem>

                    <TabItem Header="📁 Batch Activation (CSV)" FontSize="14" FontWeight="SemiBold">
                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="Select a CSV or Excel file containing multiple contracts or demands to activate them sequentially." Margin="0,0,0,15" Foreground="#7F8C8D" TextWrapping="Wrap"/>

                                <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                                    <TextBlock Text="Input Type:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <RadioButton x:Name="RbBatchActSearchContract" Content="Contract Number" IsChecked="True" Margin="0,0,15,0" VerticalAlignment="Center" Cursor="Hand" Checked="BatchActInputType_Checked"/>
                                    <RadioButton x:Name="RbBatchActSearchDemand" Content="Demand ID" VerticalAlignment="Center" Cursor="Hand" Checked="BatchActInputType_Checked"/>
                                </StackPanel>

                                <TextBlock Text="Data File path (CSV/XLS):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                <Grid Margin="0,0,0,25">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtBatchActCsv" IsReadOnly="True" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,10,0"/>
                                    <Button Content="Browse..." Grid.Column="1" Padding="15,8" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseActCsv_Click"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="BtnCancelBatchAct" Content="🛑 Cancel" Click="BtnCancelActivation_Click" Style="{StaticResource CancelButtonStyle}" Width="120" Margin="0,0,10,0" IsEnabled="False"/>
                                    <Button x:Name="BtnRunBatchAct" Content="🚀 Run Batch Activation" Click="BtnRunBatchActivation_Click" Style="{StaticResource ActionButtonStyle}" Width="220"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>

            <Grid x:Name="GridComparison" Grid.Row="0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Comparison Module" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                </StackPanel>

                <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Select the base and target CSV files to compare. All tables within the files will be analyzed automatically." Margin="0,0,0,15" Foreground="#7F8C8D" TextWrapping="Wrap"/>

                        <TextBlock Text="Base Extraction File:" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtBaseFile" IsReadOnly="True" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,10,0" Background="#F9F9F9"/>
                            <Button Content="Browse..." Grid.Column="1" Padding="15,8" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseBase_Click"/>
                        </Grid>

                        <TextBlock Text="Target Extraction File (to compare against):" Margin="0,0,0,5" FontWeight="SemiBold" Foreground="#2C3E50"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtTargetFile" IsReadOnly="True" Padding="8" FontSize="14" BorderBrush="#DCDDE1" Margin="0,0,10,0" Background="#F9F9F9"/>
                            <Button Content="Browse..." Grid.Column="1" Padding="15,8" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand" Click="BtnBrowseTarget_Click"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnOpenComparisonFolder" Content="📁 Open Report Folder" Click="BtnOpenFolder_Click" Background="#3498DB" Foreground="White" Padding="15,10" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button x:Name="BtnRunComparison" Content="🚀 Run Deep Comparison" Click="BtnRunComparisonAction_Click" Style="{StaticResource ActionButtonStyle}" Width="240" IsEnabled="False"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border x:Name="PanelDashboard" Grid.Row="0" Background="White" CornerRadius="8" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,0,0,15" Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Width="140" Height="140" Margin="0,0,30,0">
                                <Ellipse Stroke="#ECF0F1" StrokeThickness="12" Fill="Transparent"/>
                                <Ellipse x:Name="CircleProgress" Stroke="#2ECC71" StrokeThickness="12" Fill="Transparent"
                                         StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtScorePercentage" Text="0%" FontSize="32" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Match" FontSize="14" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtDashboardTitle" Text="Analyse terminée avec succès !" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Lignes analysées" FontSize="13" Foreground="#7F8C8D"/>
                                        <TextBlock x:Name="TxtTotalRows" Text="0" FontSize="22" FontWeight="Bold" Foreground="#34495E"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Erreurs trouvées" FontSize="13" Foreground="#7F8C8D"/>
                                        <TextBlock x:Name="TxtTotalErrors" Text="0" FontSize="22" FontWeight="Bold" Foreground="#E74C3C"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="GridResults" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="White" BorderBrush="#DCDDE1" BorderThickness="1" HeadersVisibility="Column"
                              RowBackground="White" AlternatingRowBackground="#F9F9F9" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#ECF0F1" Visibility="Collapsed">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#2C3E50"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Padding" Value="5"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Status" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusColor}" CornerRadius="4" Padding="5,2" Margin="5" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding StatusIcon}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Test ID &amp; Table" Binding="{Binding TableName}" Width="200" FontWeight="SemiBold"/>

                            <DataGridTemplateColumn Header="Détails" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ErrorDetails}" TextWrapping="Wrap" Foreground="#7F8C8D" Margin="5"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="TxtComparisonWaiting" Grid.Row="1" Text="Sélectionnez vos fichiers et lancez la comparaison."
                               Foreground="#BDC3C7" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                </Grid>
            </Grid>

            <Grid x:Name="GridHelp" Grid.Row="0" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Help &amp; Documentation Center" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,10">
                    <StackPanel Margin="0,0,15,0">

                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#DCDDE1" BorderThickness="1" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="Welcome to the E.T.L Comparison Tool" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <TextBlock Text="This software allows you to activate, extract, and compare contractual data individually or in batches. Please read the instructions below carefully to format your data files correctly and understand potential error codes." TextWrapping="Wrap" Foreground="#7F8C8D" LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#3498DB" BorderThickness="2" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="📥 Extraction Module &amp; File Rules (Batch)" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <TextBlock Text="The extraction module allows you to retrieve data from D000 or Q000 environments. When using batch extraction, your Excel or CSV files MUST adhere to the following templates:" TextWrapping="Wrap" Foreground="#7F8C8D" LineHeight="20" Margin="0,0,0,15"/>

                                <TextBlock Text="1. Search by Contract ID:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                <TextBlock Text="The program scans your file looking for a column named exactly 'LISA Contract'. Ensure that your column header has this name, with no extra spaces." TextWrapping="Wrap" Foreground="#7F8C8D" Margin="20,0,0,10"/>

                                <Border BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="4" Margin="20,0,0,15" HorizontalAlignment="Left">
                                    <Image Source="/Images/TemplateContractLisa.png" Width="400" Stretch="Uniform"/>
                                </Border>

                                <TextBlock Text="2. Search by Demand ID:" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,5"/>
                                <TextBlock Text="The program looks for a column named 'Value'. Note: the system expects this column to be located on the second row (Row 2) of your Excel file to find all Demand IDs." TextWrapping="Wrap" Foreground="#7F8C8D" Margin="20,0,0,10"/>

                                <Border BorderBrush="#DCDDE1" BorderThickness="1" CornerRadius="4" Margin="20,0,0,15" HorizontalAlignment="Left">
                                    <Image Source="/Images/TemplateDemandValue.png" Width="400" Stretch="Uniform"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#1ABC9C" BorderThickness="2" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="⚡ Activation Module &amp; Troubleshooting" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <TextBlock Text="This module allows you to send payment or activation commands to the target environment. You must set the CUS Code, bureau number (BUCP), and the command (CMDPMT)." TextWrapping="Wrap" Foreground="#7F8C8D" LineHeight="20" Margin="0,0,0,15"/>

                                <TextBlock Text="Common Errors:" FontWeight="Bold" Foreground="#E74C3C" Margin="0,0,0,5"/>
                                <Border Background="#FDEDEC" CornerRadius="4" Padding="15" BorderBrush="#E74C3C" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="❌ Error 008 (Job 'addprct')" FontWeight="Bold" Foreground="#C0392B"/>
                                        <TextBlock Text="If during activation, the console or report returns a specific 008 error for the addprct job, it is highly likely that a premium has already been assigned to this contract/demand. The activation is therefore blocked by the central system to prevent duplicates." TextWrapping="Wrap" Foreground="#C0392B" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="White" CornerRadius="5" Padding="20" BorderBrush="#9B59B6" BorderThickness="2" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="📊 Comparison Module" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" Margin="0,0,0,10"/>
                                <TextBlock Text="This module analyzes two extracted CSV/Excel files. It automatically detects the tables present in the base file and compares them against the target file. The final report generated in the folder (which can be opened via the blue button) will highlight discrepancies, missing rows, or premium differences." TextWrapping="Wrap" Foreground="#7F8C8D" LineHeight="20"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,15,0,0">
                <ProgressBar x:Name="PrgLoading" IsIndeterminate="True" Height="4" Margin="0,0,0,10" Visibility="Collapsed" Foreground="#3498DB"/>
                <TextBlock x:Name="TxtStatus" FontSize="14" TextWrapping="Wrap" Foreground="#2F3640" FontWeight="SemiBold" Text="Ready."/>
                <TextBlock x:Name="LnkFile" Visibility="Collapsed" Margin="0,5,0,0" FontSize="14">
                    <Hyperlink Click="Hyperlink_Click" Foreground="#2980B9" FontWeight="Bold">
                        <Run Text="📁 Click here to open generated file/report"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

        </Grid>
    </Grid>
</Window>